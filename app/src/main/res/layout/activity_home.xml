<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/topTitle"
        android:layout_width="wrap_content"
        android:layout_height="55dp"
        android:layout_margin="18dp"
        android:background="@drawable/top_card_bg"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="🗺️  VILLAGE FLOW"
        android:textColor="#071A3A"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/liveBadge"
        android:layout_width="80dp"
        android:layout_height="42dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/dark_round_bg"
        android:gravity="center"
        android:text="● LIVE"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="105dp"
        android:background="@drawable/status_card_bg"
        android:gravity="center"
        android:text="🚜 TRACTOR STARTING...\nPlease wait"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/arrivalAlertBox"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_gravity="top"
        android:layout_marginStart="18dp"
        android:layout_marginTop="90dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/arrival_alert_bg"
        android:gravity="center"
        android:text="🚜 Arrival Alert"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="95dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/navMap"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🗺️\nMAP"
            android:textColor="#00B85C"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navReport"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📷\nREPORT"
            android:textColor="#8FA0BD"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navGuide"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📖\nGUIDE"
            android:textColor="#8FA0BD"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="👤\nPROFILE"
            android:textColor="#8FA0BD"
            android:textSize="12sp"
            android:textStyle="bold" />


    </LinearLayout>

</FrameLayout>