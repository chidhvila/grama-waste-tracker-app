<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/guideScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FAFD"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="60dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/backBtnGuide"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="←"
                android:textColor="#061736"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/guideTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Waste Guide"
                android:textColor="#061736"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dry Waste -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/dry_waste_bg"
            android:orientation="vertical"
            android:padding="26dp">

            <TextView
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/dry_icon_bg"
                android:gravity="center"
                android:text="🗑️"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/dryWasteTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="DRY WASTE"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dryWasteDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:lineSpacingExtra="7dp"
                android:text="• Plastic bottles&#10;• Milk packets&#10;• Paper and cardboard&#10;• Glass bottles&#10;• Metal cans&#10;• E-waste&#10;• Cartons and boxes"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Keep dry waste clean and separate."
                android:textColor="#DDEAFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Wet Waste -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:background="@drawable/wet_waste_bg"
            android:orientation="vertical"
            android:padding="26dp">

            <TextView
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/wet_icon_bg"
                android:gravity="center"
                android:text="🍃"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/wetWasteTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="WET WASTE"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/wetWasteDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:lineSpacingExtra="7dp"
                android:text="• Food waste&#10;• Vegetable peels&#10;• Fruit skins&#10;• Leftover food&#10;• Tea powder&#10;• Flowers and leaves&#10;• Egg shells"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Wet waste can be used for composting."
                android:textColor="#D6F8E8"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Clean Village Habits -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:background="@drawable/guide_white_card_bg"
            android:orientation="vertical"
            android:padding="26dp">

            <TextView
                android:id="@+id/habitsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CLEAN VILLAGE HABITS"
                android:textColor="#061736"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/habitOneTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="1. SEPARATE AT SOURCE"
                android:textColor="#061736"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/habitOneDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Use two bins: blue for dry waste and green for wet waste."
                android:textColor="#516C9A"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/habitTwoTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="2. NO DUMPING"
                android:textColor="#061736"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/habitTwoDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Always hand over waste to the Panchayat tractor."
                android:textColor="#516C9A"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/habitThreeTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="3. WASH AND DRY"
                android:textColor="#061736"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/habitThreeDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Rinse plastic food containers before disposal."
                android:textColor="#516C9A"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/habitFourTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="4. COMMUNITY VIGIL"
                android:textColor="#061736"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/habitFourDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Report illegal dumping spots using the app."
                android:textColor="#516C9A"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>