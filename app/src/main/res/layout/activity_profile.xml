<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="40dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Account"
            android:textColor="#071A3A"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_marginTop="45dp"
            android:background="@drawable/ic_logo"
            android:gravity="center"
            android:textColor="#C6D3E4"
            android:textSize="55sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="45dp"
            android:text="Village Connect"
            android:textColor="#061736"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Join the Grama-Waste network to protect your\nvillage environment."
            android:textAlignment="center"
            android:lineSpacingExtra="5dp"
            android:textColor="#516C9A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnGoogleSignIn"
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/google_button_bg"
            android:text="↪   SIGN IN WITH GOOGLE"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.18"
            android:fontFamily="sans-serif-black"
            android:stateListAnimator="@null" />

        <TextView
            android:id="@+id/registerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="22dp"
            android:text="New user? Register here"
            android:textColor="#00B85C"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:text="SMART VILLAGE INITIATIVE"
            android:textColor="#D5DEE9"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.35" />

    </LinearLayout>

</ScrollView>