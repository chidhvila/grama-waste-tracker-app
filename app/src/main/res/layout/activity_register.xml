<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FAFD">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/backToLoginBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="#061736"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="35dp"
            android:text="Create Account"
            android:textColor="#061736"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Register as a citizen and join Village Connect."
            android:textColor="#516C9A"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="35dp"
            android:background="@drawable/profile_card_bg"
            android:orientation="vertical"
            android:padding="24dp">

            <EditText
                android:id="@+id/nameInput"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Full Name"
                android:padding="14dp"
                android:textColor="#061736"
                android:textColorHint="#9AAAC0"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/phoneInput"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Phone Number"
                android:inputType="phone"
                android:padding="14dp"
                android:textColor="#061736"
                android:textColorHint="#9AAAC0"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/villageInput"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Village Name"
                android:padding="14dp"
                android:textColor="#061736"
                android:textColorHint="#9AAAC0"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/emailInput"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Email Address"
                android:inputType="textEmailAddress"
                android:padding="14dp"
                android:textColor="#061736"
                android:textColorHint="#9AAAC0"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Password"
                android:inputType="textPassword"
                android:padding="14dp"
                android:textColor="#061736"
                android:textColorHint="#9AAAC0"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/registerBtn"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/submit_btn_bg"
                android:gravity="center"
                android:text="REGISTER"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>