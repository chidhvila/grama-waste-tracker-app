<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FAFD"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/backBtnReport"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="←"
                android:textColor="#061736"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/reportTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Report Blackspot"
                android:textColor="#061736"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/report_card_bg"
            android:elevation="4dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/previewImage"
                android:layout_width="105dp"
                android:layout_height="105dp"
                android:background="@drawable/camera_box_bg"
                android:clickable="true"
                android:contentDescription="Photo Preview"
                android:focusable="true"
                android:padding="24dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_camera" />

            <Button
                android:id="@+id/btnCapturePhoto"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginTop="12dp"
                android:background="@android:color/transparent"
                android:text="TAP TO CAPTURE PHOTO"
                android:textColor="#061736"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnExamplePhoto"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:background="@android:color/transparent"
                android:text="UPLOAD PHOTO"
                android:textColor="#00B85C"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/locationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌖  Searching for signal..."
                android:textColor="#7D91AE"
                android:textSize="11sp"
                android:textStyle="italic" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/analysisTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ANALYSIS &amp; DETAILS"
                    android:textColor="#8FA0BD"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/aiReadyText"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:background="@drawable/ai_ready_bg"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="AI READY"
                    android:textColor="#00B85C"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <EditText
                android:id="@+id/issueText"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_bg"
                android:gravity="top"
                android:hint="Describe the issue... e.g. Type of waste, size, or landmarks"
                android:padding="14dp"
                android:textColor="#061736"
                android:textColorHint="#C6D3E4"
                android:textSize="12sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/tagPlastic"
                        style="@style/ReportTagButton"
                        android:text="+ Plastic waste" />

                    <Button
                        android:id="@+id/tagLarge"
                        style="@style/ReportTagButton"
                        android:text="+ Large dump" />

                    <Button
                        android:id="@+id/tagSmell"
                        style="@style/ReportTagButton"
                        android:text="+ Foul smell" />

                    <Button
                        android:id="@+id/tagBlocking"
                        style="@style/ReportTagButton"
                        android:text="+ Blocking path" />

                    <Button
                        android:id="@+id/tagLandmark"
                        style="@style/ReportTagButton"
                        android:text="+ Near landmark" />

                </LinearLayout>
            </HorizontalScrollView>

            <Button
                android:id="@+id/btnSubmitReport"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/submit_btn_bg"
                android:text="✈  SUBMIT REPORT"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>